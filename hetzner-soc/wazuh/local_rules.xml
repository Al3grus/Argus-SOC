<!-- Argus SOC — Custom Wazuh Detection Rules -->
<!-- Location: /var/ossec/etc/rules/local_rules.xml on Hetzner VPS -->
<!-- Documentation: https://documentation.wazuh.com/current/user-manual/ruleset/custom.html -->
<!--                                                                              -->
<!-- Rules are written based on red team findings from Phase 4 scenarios.         -->
<!-- Each rule maps to a specific detection gap identified during attack exercises. -->

<group name="local,argus,">

  <!-- Rule 100001: SSH login from Pi 5 / Metasploitable IP — lateral movement indicator -->
  <!-- Fires when Pi 5 (or Docker containers on it) initiates SSH to Pi 3B+ -->
  <!-- Scenario 5 — T1021 Remote Services -->
  <rule id="100001" level="12">
    <if_sid>5715</if_sid>
    <srcip>192.168.1.10</srcip>
    <description>SSH login from client infrastructure IP (192.168.1.10) — lateral movement indicator (T1021)</description>
    <mitre>
      <id>T1021</id>
    </mitre>
    <group>authentication_success,lateral_movement,</group>
  </rule>

  <!-- Rule 100002: SSH accepted from any unexpected internal host -->
  <!-- Fires when any internal device other than known management hosts authenticates via SSH -->
  <!-- Scenario 5 — T1078 Valid Accounts -->
  <rule id="100002" level="14">
    <if_sid>5715</if_sid>
    <srcip>!192.168.1.10</srcip>
    <srcip>!10.0.0.0/24</srcip>
    <match>Accepted</match>
    <description>SSH accepted from unexpected source — possible lateral movement (T1078)</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,lateral_movement,</group>
  </rule>

  <!-- Rule 100003: Cowrie post-login command execution — active compromise -->
  <!-- Fires when attacker executes commands in Cowrie honeypot after successful login -->
  <!-- Scenario 2 — T1059 Command and Scripting Interpreter -->
  <rule id="100003" level="14">
    <if_sid>5710</if_sid>
    <field name="eventid">^cowrie.command.input$</field>
    <description>Cowrie honeypot — attacker executing commands post-login. Active compromise indicator (T1059)</description>
    <mitre>
      <id>T1059</id>
    </mitre>
    <group>honeypot,active_compromise,</group>
  </rule>

  <!-- Rule 100004: Cowrie file download attempt -->
  <!-- Fires when attacker attempts to download files in Cowrie session -->
  <!-- Scenario 2 — T1105 Ingress Tool Transfer -->
  <rule id="100004" level="15">
    <if_sid>5710</if_sid>
    <field name="eventid">^cowrie.session.file_download$</field>
    <description>Cowrie honeypot — attacker attempting file download. Malware staging indicator (T1105)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>honeypot,malware_staging,</group>
  </rule>

  <!-- Rule 100005: Internal host scanning the network -->
  <!-- Fires when a Suricata SCAN alert originates from an internal host -->
  <!-- Scenario 5 — T1046 Network Service Discovery (post-compromise) -->
  <rule id="100005" level="13">
    <if_sid>86601</if_sid>
    <field name="data.srcip">^192\.168\.1\.</field>
    <field name="data.srcip" negate="yes">192.168.1.20</field>
    <description>Suricata SCAN alert from unexpected internal host — possible compromised host scanning (T1046)</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>network_scan,lateral_movement,</group>
  </rule>

  <!-- Rule 100006: DNS query to high-risk TLD -->
  <!-- Fires on Pi-hole logs when a client queries a domain with a high-risk TLD -->
  <!-- Detection Engineering — DGA domain pattern -->
  <rule id="100006" level="8">
    <if_sid>100200</if_sid>
    <regex>\.tk$|\.top$|\.xyz$|\.pw$|\.cc$|\.ru$</regex>
    <description>DNS query to high-risk TLD — possible DGA or C2 domain (T1071.004)</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
    <group>dns,possible_c2,</group>
  </rule>

</group>
